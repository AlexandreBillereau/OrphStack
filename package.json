{
  "name": "orphstack",
  "version": "0.0.1",
  "private": true,
  "description": "WordPress tooling CLI (step-by-step prompts via Clack)",
  "type": "module",
  "bin": {
    "orphstack": "./dist/index.js"
  },
  "files": [
    "dist",
    "commands",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "orphstack": "tsx src/index.ts",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
